# Agent Directory Schema Extension - Agent Attributes
#
# IMPORTANT: Before production use, replace {PEN} with your IANA Private Enterprise Number
# To obtain a PEN (free): https://www.iana.org/assignments/enterprise-numbers/
#
# Base OID: 1.3.6.1.4.1.{PEN}
# Attribute OIDs: 1.3.6.1.4.1.{PEN}.2.x
#
# This file defines all custom attributes for the msDS-Agent object class.

# ============================================================================
# msDS-AgentType
# Classification of the agent: autonomous, assistant, tool, orchestrator
# ============================================================================
dn: CN=msDS-AgentType,CN=Schema,CN=Configuration,DC=X
changetype: add
objectClass: attributeSchema
cn: msDS-AgentType
lDAPDisplayName: msDS-AgentType
adminDisplayName: Agent Type
adminDescription: Classification of the agent (autonomous, assistant, tool, orchestrator)
attributeId: 1.3.6.1.4.1.99999.2.1
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 1
showInAdvancedViewOnly: FALSE
systemOnly: FALSE

# ============================================================================
# msDS-AgentCapabilities
# List of registered capabilities/skills the agent has
# ============================================================================
dn: CN=msDS-AgentCapabilities,CN=Schema,CN=Configuration,DC=X
changetype: add
objectClass: attributeSchema
cn: msDS-AgentCapabilities
lDAPDisplayName: msDS-AgentCapabilities
adminDisplayName: Agent Capabilities
adminDescription: List of registered capabilities the agent possesses
attributeId: 1.3.6.1.4.1.99999.2.2
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: FALSE
searchFlags: 1
showInAdvancedViewOnly: FALSE
systemOnly: FALSE

