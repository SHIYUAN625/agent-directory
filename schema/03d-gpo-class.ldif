# Agent Directory Schema Extension - Instruction GPO Object Class
#
# IMPORTANT: Before production use, replace {PEN} with your IANA Private Enterprise Number
# To obtain a PEN (free): https://www.iana.org/assignments/enterprise-numbers/
#
# Base OID: 1.3.6.1.4.1.{PEN}
# Class OID: 1.3.6.1.4.1.{PEN}.1.5
#
# This file defines the msDS-AgentInstructionGPO structural class.
# Prerequisites: 02c-gpo-attributes.ldif must be loaded first.

# ============================================================================
# msDS-AgentInstructionGPO Object Class
#
# Instruction Resolution at Agent Boot:
#   1. Query own msDS-AgentInstructionGPOs for directly linked GPOs
#   2. Query all instruction GPOs where scope matches:
#      - msDS-GPOAppliesToTypes contains agent's msDS-AgentType, OR is empty
#      - msDS-GPOAppliesToTrustLevels contains agent's msDS-AgentTrustLevel, OR is empty
#      - msDS-GPOAppliesToGroups contains a group the agent belongs to, OR is empty
#   3. Filter to msDS-GPOEnabled=TRUE only
#   4. Sort by msDS-GPOPriority (ascending - lowest first, highest last)
#   5. Fetch instruction files from SYSVOL via SMB
#   6. Merge according to each GPO's msDS-GPOMergeStrategy:
#      - "append" (default): concatenate after previous instructions
#      - "prepend": insert before previous instructions
#      - "replace": discard all lower-priority instructions
#   7. Result = the agent's effective system prompt
# ============================================================================

dn: CN=msDS-AgentInstructionGPO,CN=Schema,CN=Configuration,DC=X
changetype: add
objectClass: classSchema
cn: msDS-AgentInstructionGPO
lDAPDisplayName: msDS-AgentInstructionGPO
adminDisplayName: Agent Instruction GPO
adminDescription: Group Policy Object that delivers system prompt instructions to agents
governsId: 1.3.6.1.4.1.99999.1.5
objectClassCategory: 1
subClassOf: top
rdnAttId: cn
showInAdvancedViewOnly: FALSE
defaultHidingValue: FALSE
systemOnly: FALSE
defaultObjectCategory: CN=msDS-AgentInstructionGPO,CN=Schema,CN=Configuration,DC=X
#
# mustContain: Required attributes for instruction GPOs
#
mustContain: cn
mustContain: msDS-GPOInstructionPath
mustContain: msDS-GPOPriority
#
# mayContain: Optional attributes for instruction GPOs
#
mayContain: msDS-GPODisplayName
mayContain: msDS-GPOMergeStrategy
mayContain: msDS-GPOAppliesToTypes
mayContain: msDS-GPOAppliesToTrustLevels
mayContain: msDS-GPOAppliesToGroups
mayContain: msDS-GPOEnabled
mayContain: msDS-GPOVersion
mayContain: description
#
# possSuperiors: Containers where instruction GPOs can be created
#
possSuperiors: container
possSuperiors: organizationalUnit
