# Agent Directory Schema Extension - Default Tool Definitions
#
# This file creates pre-defined tool objects for common applications and utilities.
# These provide a starting point for tool-based authorization.
#
# Prerequisites:
#   - Tool class (04-tool-class.ldif) must be loaded
#   - Agent Tools container (05-containers.ldif) must be created
#
# IMPORTANT: Replace DC=X with your actual domain components
# Example: DC=corp,DC=contoso,DC=com

# ============================================================================
# SHELL & SCRIPTING TOOLS
# ============================================================================

dn: CN=microsoft.powershell,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: microsoft.powershell
msDS-ToolIdentifier: microsoft.powershell
msDS-ToolDisplayName: PowerShell
msDS-ToolCategory: shell
msDS-ToolExecutable: %SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe
msDS-ToolRiskLevel: 4
msDS-ToolRequiredTrustLevel: 2
msDS-ToolConstraints: ExecutionPolicy=RemoteSigned
msDS-ToolConstraints: TranscriptLogging=Required
msDS-ToolAuditRequired: TRUE
description: Windows PowerShell command-line shell and scripting language

dn: CN=microsoft.powershell.constrained,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: microsoft.powershell.constrained
msDS-ToolIdentifier: microsoft.powershell.constrained
msDS-ToolDisplayName: PowerShell (Constrained Language)
msDS-ToolCategory: shell
msDS-ToolExecutable: %SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe
msDS-ToolRiskLevel: 2
msDS-ToolRequiredTrustLevel: 1
msDS-ToolConstraints: LanguageMode=ConstrainedLanguage
msDS-ToolConstraints: NoAddType=True
msDS-ToolConstraints: TranscriptLogging=Required
msDS-ToolAuditRequired: TRUE
description: PowerShell with Constrained Language Mode for restricted operations

dn: CN=microsoft.cmd,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: microsoft.cmd
msDS-ToolIdentifier: microsoft.cmd
msDS-ToolDisplayName: Command Prompt
msDS-ToolCategory: shell
msDS-ToolExecutable: %SystemRoot%\System32\cmd.exe
msDS-ToolRiskLevel: 3
msDS-ToolRequiredTrustLevel: 2
msDS-ToolAuditRequired: TRUE
description: Windows Command Prompt (cmd.exe)

dn: CN=gnu.bash,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: gnu.bash
msDS-ToolIdentifier: gnu.bash
msDS-ToolDisplayName: Bash Shell
msDS-ToolCategory: shell
msDS-ToolExecutable: /bin/bash
msDS-ToolRiskLevel: 3
msDS-ToolRequiredTrustLevel: 2
msDS-ToolAuditRequired: TRUE
description: GNU Bash shell (native or via WSL)

dn: CN=python.interpreter,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: python.interpreter
msDS-ToolIdentifier: python.interpreter
msDS-ToolDisplayName: Python Interpreter
msDS-ToolCategory: development
msDS-ToolExecutable: python.exe
msDS-ToolRiskLevel: 3
msDS-ToolRequiredTrustLevel: 2
msDS-ToolAuditRequired: TRUE
description: Python programming language interpreter

