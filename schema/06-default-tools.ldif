msDS-ToolRiskLevel: 4
msDS-ToolRequiredTrustLevel: 2
msDS-ToolConstraints: ConnectionStringWhitelist=Required
msDS-ToolConstraints: DDLOperations=Prohibited
msDS-ToolConstraints: QueryTimeout=30
msDS-ToolConstraints: RowLimit=10000
msDS-ToolAuditRequired: TRUE
