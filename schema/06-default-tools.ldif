dn: CN=database.sql,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: database.sql
msDS-ToolIdentifier: database.sql
msDS-ToolDisplayName: SQL Query Execution
msDS-ToolCategory: data
