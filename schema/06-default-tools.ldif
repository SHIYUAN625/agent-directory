dn: CN=network.ssh,CN=Agent Tools,CN=System,DC=X
changetype: add
objectClass: msDS-AgentTool
cn: network.ssh
msDS-ToolIdentifier: network.ssh
msDS-ToolDisplayName: SSH Client
msDS-ToolCategory: network
