# Autonomous Enterprise AD Schema Extension - Instruction GPO Object Class (Samba4)
#
# IMPORTANT: Before production use, replace 99999 with your IANA Private Enterprise Number
# To obtain a PEN (free): https://www.iana.org/assignments/enterprise-numbers/
#
# Base OID: 1.3.6.1.4.1.{PEN}
# Class OID: 1.3.6.1.4.1.{PEN}.1.5
#
# This file defines the x-agentInstructionGPO structural class.
# Prerequisites: 01c-instruction-gpo-attributes.ldif must be loaded first.

# ============================================================================
# x-agentInstructionGPO Object Class
#
# Inherits from: top
#
# This class represents a Group Policy Object that delivers system prompt
# instructions to agents. It follows the standard AD GPO pattern:
#
#   - Metadata stored in AD (this object)
#   - Content (markdown instructions) stored in SYSVOL
#   - Scoped by agent type, trust level, and/or group membership
#   - Layered by priority with configurable merge strategy
#
# Instruction Resolution at Agent Boot:
#   1. Query own x-agent-InstructionGPOs for directly linked GPOs
#   2. Query all instruction GPOs where scope matches:
#      - x-gpo-AppliesToTypes contains agent's x-agent-Type, OR is empty
#      - x-gpo-AppliesToTrustLevels contains agent's x-agent-TrustLevel, OR is empty
#      - x-gpo-AppliesToGroups contains a group the agent belongs to, OR is empty
#   3. Filter to x-gpo-Enabled=TRUE only
#   4. Sort by x-gpo-Priority (ascending — lowest first, highest last)
#   5. Fetch instruction files from SYSVOL via SMB
#   6. Merge according to each GPO's x-gpo-MergeStrategy:
#      - "append" (default): concatenate after previous instructions
#      - "prepend": insert before previous instructions
#      - "replace": discard all lower-priority instructions
#   7. Result = the agent's effective system prompt
#
# Example layering:
#   Priority 0:   base-agent-instructions      (all agents)
#   Priority 100: type-assistant-instructions   (assistant type)
#   Priority 400: claude-assistant-01-override  (agent-specific)
# ============================================================================

dn: CN=x-agentInstructionGPO,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: classSchema
cn: x-agentInstructionGPO
lDAPDisplayName: x-agentInstructionGPO
adminDisplayName: Agent Instruction GPO
adminDescription: Group Policy Object that delivers system prompt instructions to agents
governsId: 1.3.6.1.4.1.99999.1.5
objectClassCategory: 1
subClassOf: top
rdnAttId: cn
showInAdvancedViewOnly: FALSE
defaultHidingValue: FALSE
systemOnly: FALSE
defaultObjectCategory: CN=x-agentInstructionGPO,CN=Schema,CN=Configuration,DC=autonomy,DC=local
#
# mustContain: Required attributes
#
mustContain: cn
mustContain: x-gpo-InstructionPath
mustContain: x-gpo-Priority
#
# mayContain: Optional attributes
#
mayContain: x-gpo-DisplayName
mayContain: x-gpo-MergeStrategy
mayContain: x-gpo-AppliesToTypes
mayContain: x-gpo-AppliesToTrustLevels
mayContain: x-gpo-AppliesToGroups
mayContain: x-gpo-Enabled
mayContain: x-gpo-Version
mayContain: description
#
# possSuperiors: Containers where instruction GPOs can be created
#
possSuperiors: container
possSuperiors: organizationalUnit
