adminDescription: JSON-encoded LLM quota (daily_tokens, max_context)
attributeId: 1.3.6.1.4.1.99999.2.16
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 0

