# Autonomous Enterprise AD Schema Extension - Policy Object Class (Samba4)
#
# IMPORTANT: Before production use, replace 99999 with your IANA Private Enterprise Number
# To obtain a PEN (free): https://www.iana.org/assignments/enterprise-numbers/
#
# Base OID: 1.3.6.1.4.1.{PEN}
# Class OID: 1.3.6.1.4.1.{PEN}.1.3
#
# This file defines the x-agentPolicy structural class.
# Prerequisites: 03-policy-attributes.ldif must be loaded first.

# ============================================================================
# x-agentPolicy Object Class
#
# Inherits from: top
#
# This class represents policies that control agent behavior. Policies follow
# a GPO-like pattern:
#   - Policy metadata stored in AD (this object)
#   - Policy content (JSON) stored in SYSVOL
#
# Policy Inheritance:
#   Base Policy (Priority 0)      -> All agents
#       |
#   Type Policy (Priority 100)    -> By agent type (developer, coordinator)
#       |
#   Agent-Specific (Priority 200) -> Individual agent overrides
#
# At boot, agents:
#   1. Query LDAP for own attributes + x-agent-Policies
#   2. Fetch linked policy JSONs from SYSVOL via SMB
#   3. Merge by priority (higher wins)
#   4. Apply to bwrap, credential broker, runtime config
# ============================================================================

dn: CN=x-agentPolicy,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: classSchema
cn: x-agentPolicy
lDAPDisplayName: x-agentPolicy
adminDisplayName: Agent Policy
adminDescription: Policy object controlling agent behavior (GPO-like pattern)
governsId: 1.3.6.1.4.1.99999.1.3
objectClassCategory: 1
subClassOf: top
rdnAttId: cn
showInAdvancedViewOnly: FALSE
defaultHidingValue: FALSE
systemOnly: FALSE
defaultObjectCategory: CN=x-agentPolicy,CN=Schema,CN=Configuration,DC=autonomy,DC=local
#
# mustContain: Required attributes for policies
#
mustContain: cn
mustContain: x-policy-Identifier
mustContain: x-policy-Type
mustContain: x-policy-Priority
#
# mayContain: Optional attributes for policies
#
mayContain: x-policy-Path
mayContain: x-policy-AppliesToTypes
mayContain: x-policy-AppliesToTrustLevels
mayContain: x-policy-Enabled
mayContain: x-policy-Version
mayContain: description
#
# possSuperiors: Containers where policies can be created
#
possSuperiors: container
possSuperiors: organizationalUnit

