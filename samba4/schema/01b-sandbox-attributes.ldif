# Autonomous Enterprise AD Schema Extension - Sandbox Attributes (Samba4)
#
# IMPORTANT: Before production use, replace 99999 with your IANA Private Enterprise Number
# To obtain a PEN (free): https://www.iana.org/assignments/enterprise-numbers/
#
# Base OID: 1.3.6.1.4.1.{PEN}
# Attribute OIDs: 1.3.6.1.4.1.{PEN}.2.50-.2.55
#
# This file defines custom attributes for sandbox execution environments.
# Adapted from Windows AD schema for Samba4 compatibility.

# ============================================================================
# SANDBOX ATTRIBUTES
# ============================================================================

# x-sandbox-Endpoint
# URI where the sandbox runtime is accessible
dn: CN=x-sandbox-Endpoint,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: attributeSchema
cn: x-sandbox-Endpoint
lDAPDisplayName: x-sandbox-Endpoint
adminDisplayName: Sandbox Endpoint
adminDescription: URI endpoint where the sandbox runtime is accessible
attributeId: 1.3.6.1.4.1.99999.2.50
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 0

# x-sandbox-Agents
# Distinguished names of agents that can run in this sandbox
dn: CN=x-sandbox-Agents,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: attributeSchema
cn: x-sandbox-Agents
lDAPDisplayName: x-sandbox-Agents
adminDisplayName: Sandbox Agents
adminDescription: Distinguished names of agents authorized to run in this sandbox
attributeId: 1.3.6.1.4.1.99999.2.51
attributeSyntax: 2.5.5.1
oMSyntax: 127
isSingleValued: FALSE
searchFlags: 1

# x-sandbox-ResourcePolicy
# JSON-encoded resource constraints (CPU, memory, disk limits)
dn: CN=x-sandbox-ResourcePolicy,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: attributeSchema
cn: x-sandbox-ResourcePolicy
lDAPDisplayName: x-sandbox-ResourcePolicy
adminDisplayName: Sandbox Resource Policy
adminDescription: JSON-encoded resource constraints for the sandbox (CPU, memory, disk)
attributeId: 1.3.6.1.4.1.99999.2.52
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 0

# x-sandbox-NetworkPolicy
# JSON-encoded network rules (allowed hosts, ports, protocols)
dn: CN=x-sandbox-NetworkPolicy,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: attributeSchema
cn: x-sandbox-NetworkPolicy
lDAPDisplayName: x-sandbox-NetworkPolicy
adminDisplayName: Sandbox Network Policy
adminDescription: JSON-encoded network rules for the sandbox (allowed hosts, ports, protocols)
attributeId: 1.3.6.1.4.1.99999.2.53
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 0

# x-sandbox-SecurityProfile
# Sandbox isolation technology (bwrap, appcontainer, hyperv, etc.)
dn: CN=x-sandbox-SecurityProfile,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: attributeSchema
cn: x-sandbox-SecurityProfile
lDAPDisplayName: x-sandbox-SecurityProfile
adminDisplayName: Sandbox Security Profile
adminDescription: Sandbox isolation technology (bwrap, appcontainer, hyperv, vmware, none)
attributeId: 1.3.6.1.4.1.99999.2.54
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 1

# x-sandbox-Status
# Current sandbox lifecycle status
dn: CN=x-sandbox-Status,CN=Schema,CN=Configuration,DC=autonomy,DC=local
changetype: add
objectClass: attributeSchema
cn: x-sandbox-Status
lDAPDisplayName: x-sandbox-Status
adminDisplayName: Sandbox Status
adminDescription: Current sandbox lifecycle status (active, standby, terminated)
attributeId: 1.3.6.1.4.1.99999.2.55
attributeSyntax: 2.5.5.12
oMSyntax: 64
isSingleValued: TRUE
searchFlags: 1
