x-tool-RiskLevel: 3
x-tool-RequiredTrust: 2
x-tool-Constraints: dangerous_commands=prohibited
x-tool-AuditRequired: TRUE
description: Redis database client

dn: CN=jq.processor,CN=Agent Tools,CN=System,DC=autonomy,DC=local
changetype: add
objectClass: x-agentTool
cn: jq.processor
