{
  "$schema": "https://autonomy.local/schemas/agent-policy-v1.json",
  "version": "1.0.0",
  "name": "type-tool",
  "description": "Policy for tool agents (specialized single-purpose)",
  "settings": {
    "execution": {
      "max_iterations": 10,
      "checkpoint_interval_steps": 0,
      "single_task_only": true
    },
    "escalation": {
      "escalate_on_blocked": false,
      "escalate_on_error_threshold": 1
    },
    "tools": {
      "allow": [],
      "inherit_from_request": true
    },
    "compute": {
      "max_memory_mb": 1024,
      "max_runtime_seconds": 300
    },
    "agents": {
      "max_spawned_agents": 0,
      "max_delegated_tasks": 0
    },
    "behavior": {
      "pull_from_queue": false,
      "invoked_by_other_agents": true,
      "stateless": true,
      "single_response": true
    }
  }
}
