# Copy to .env and fill in values
# cp .env.example .env

SAMBA_DOMAIN=AUTONOMY
SAMBA_REALM=AUTONOMY.LOCAL
# REQUIRED: set a strong password before first boot
SAMBA_ADMIN_PASSWORD=
SAMBA_DNS_FORWARDER=8.8.8.8

# REQUIRED for NATS role-based auth (e2e, coordinator, workers)
NATS_PASSWORD=
NATS_WORKER_PASSWORD=
NATS_COORDINATOR_PASSWORD=
NATS_ANALYST_PASSWORD=
