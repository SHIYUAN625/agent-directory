                           version="1"
                           channel="Admin"
                           level="win:Critical"
                           task="PolicyViolation"
                           keywords="Security"
                           template="PolicyViolationTemplate"
                           message="$(string.Event.PolicyViolationCritical)"/>

                    <event value="6020"
                           symbol="MALICIOUS_BEHAVIOR_DETECTED"
                           version="1"
                           channel="Admin"
                           level="win:Critical"
                           task="PolicyViolation"
                           keywords="Security"
                           template="PolicyViolationTemplate"
