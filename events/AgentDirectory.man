<?xml version="1.0" encoding="UTF-8"?>
<!--
    Agent Directory Event Manifest

    This instrumentation manifest defines the event provider, channels, tasks,
    and event definitions for the Agent Directory system.

    To compile:
        mc.exe -um AgentDirectory.man
        rc.exe AgentDirectory.rc
        link.exe /DLL /NOENTRY /MACHINE:X64 /OUT:AgentDirectory.dll AgentDirectory.res

    To register:
        wevtutil im AgentDirectory.man /rf:"C:\path\AgentDirectory.dll" /mf:"C:\path\AgentDirectory.dll"

    Provider GUID: {A8B9C0D1-E2F3-4A5B-6C7D-8E9F0A1B2C3D}
-->
<instrumentationManifest
    xmlns="http://schemas.microsoft.com/win/2004/08/events"
    xmlns:win="http://manifests.microsoft.com/win/2004/08/windows/events"
    xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <instrumentation>
        <events>
            <provider
                name="Microsoft-AgentDirectory"
                guid="{A8B9C0D1-E2F3-4A5B-6C7D-8E9F0A1B2C3D}"
                symbol="AGENT_DIRECTORY_PROVIDER"
                resourceFileName="AgentDirectory.dll"
                messageFileName="AgentDirectory.dll"
                parameterFileName="AgentDirectory.dll">

                <!-- Event Channels -->
                <channels>
                    <channel
                        name="Microsoft-AgentDirectory/Operational"
                        chid="Operational"
                        symbol="CHANNEL_OPERATIONAL"
                        type="Operational"
                        enabled="true"
                        isolation="Application"
                        message="$(string.Channel.Operational)">
                    </channel>

                    <channel
                        name="Microsoft-AgentDirectory/Admin"
                        chid="Admin"
                        symbol="CHANNEL_ADMIN"
                        type="Admin"
                        enabled="true"
                        isolation="Application"
                        message="$(string.Channel.Admin)">
                    </channel>

                    <channel
                        name="Microsoft-AgentDirectory/Debug"
                        chid="Debug"
                        symbol="CHANNEL_DEBUG"
                        type="Debug"
                        enabled="false"
                        isolation="Application"
                        message="$(string.Channel.Debug)">
                    </channel>
                </channels>

                <!-- Event Levels (using standard Windows levels) -->
                <levels>
                </levels>

                <!-- Event Tasks (Categories) -->
                <tasks>
                    <task name="AgentLifecycle"
                          symbol="TASK_AGENT_LIFECYCLE"
                          value="1"
                          message="$(string.Task.AgentLifecycle)"/>

                    <task name="AgentAuthentication"
                          symbol="TASK_AGENT_AUTHENTICATION"
                          value="2"
                          message="$(string.Task.AgentAuthentication)"/>

                    <task name="ToolAccess"
                          symbol="TASK_TOOL_ACCESS"
                          value="3"
                          message="$(string.Task.ToolAccess)"/>

                    <task name="ToolExecution"
                          symbol="TASK_TOOL_EXECUTION"
                          value="4"
                          message="$(string.Task.ToolExecution)"/>

                    <task name="Delegation"
                          symbol="TASK_DELEGATION"
                          value="5"
                          message="$(string.Task.Delegation)"/>

                    <task name="PolicyViolation"
                          symbol="TASK_POLICY_VIOLATION"
                          value="6"
                          message="$(string.Task.PolicyViolation)"/>

                    <task name="TrustChange"
                          symbol="TASK_TRUST_CHANGE"
                          value="7"
                          message="$(string.Task.TrustChange)"/>

                    <task name="ResourceAccess"
                          symbol="TASK_RESOURCE_ACCESS"
                          value="8"
                          message="$(string.Task.ResourceAccess)"/>

                    <task name="SandboxLifecycle"
                          symbol="TASK_SANDBOX_LIFECYCLE"
                          value="9"
                          message="$(string.Task.SandboxLifecycle)"/>

                    <task name="InstructionGPOApplication"
                          symbol="TASK_INSTRUCTION_GPO_APPLICATION"
                          value="10"
                          message="$(string.Task.InstructionGPOApplication)"/>
                </tasks>

                <!-- Opcodes -->
                <opcodes>
                    <opcode name="Start" symbol="OPCODE_START" value="10" message="$(string.Opcode.Start)"/>
                    <opcode name="Stop" symbol="OPCODE_STOP" value="11" message="$(string.Opcode.Stop)"/>
                    <opcode name="Grant" symbol="OPCODE_GRANT" value="12" message="$(string.Opcode.Grant)"/>
                    <opcode name="Revoke" symbol="OPCODE_REVOKE" value="13" message="$(string.Opcode.Revoke)"/>
                    <opcode name="Deny" symbol="OPCODE_DENY" value="14" message="$(string.Opcode.Deny)"/>
                </opcodes>

                <!-- Keywords for filtering -->
                <keywords>
                    <keyword name="Agent" symbol="KEYWORD_AGENT" mask="0x1" message="$(string.Keyword.Agent)"/>
                    <keyword name="Tool" symbol="KEYWORD_TOOL" mask="0x2" message="$(string.Keyword.Tool)"/>
                    <keyword name="Security" symbol="KEYWORD_SECURITY" mask="0x4" message="$(string.Keyword.Security)"/>
                    <keyword name="Delegation" symbol="KEYWORD_DELEGATION" mask="0x8" message="$(string.Keyword.Delegation)"/>
                    <keyword name="Audit" symbol="KEYWORD_AUDIT" mask="0x10" message="$(string.Keyword.Audit)"/>
                    <keyword name="Sandbox" symbol="KEYWORD_SANDBOX" mask="0x20" message="$(string.Keyword.Sandbox)"/>
                    <keyword name="InstructionGPO" symbol="KEYWORD_INSTRUCTION_GPO" mask="0x40" message="$(string.Keyword.InstructionGPO)"/>
                </keywords>

                <!-- Event Templates -->
                <templates>
                    <!-- Base agent event template -->
                    <template tid="AgentBaseTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Agent lifecycle template -->
                    <template tid="AgentLifecycleTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="AgentModel" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="OwnerDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ModifiedBy" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SourceIP" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Authentication template -->
                    <template tid="AuthenticationTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AuthType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SourceIP" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SourceHost" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="TargetService" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="FailureReason" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ErrorCode" inType="win:UInt32" outType="win:HexInt32"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Tool access template -->
                    <template tid="ToolAccessTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="ToolId" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ToolDisplayName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ToolCategory" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="RequiredTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="GrantType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="DenialReason" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Tool execution template -->
                    <template tid="ToolExecutionTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="ToolId" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ToolCategory" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="OnBehalfOf" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SourceIP" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="TargetResource" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CommandLine" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ResultCode" inType="win:UInt32" outType="win:HexInt32"/>
                        <data name="Duration" inType="win:UInt64" outType="xs:unsignedLong"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Delegation template -->
                    <template tid="DelegationTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="DelegationType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="OnBehalfOfSid" inType="win:SID" outType="xs:string"/>
                        <data name="OnBehalfOfName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="TargetService" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="TargetResource" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="GrantedBy" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Policy violation template -->
                    <template tid="PolicyViolationTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ViolationType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="PolicyName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ViolationDetails" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="RecommendedAction" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AutomaticAction" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Trust change template -->
                    <template tid="TrustChangeTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="OldTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="NewTrustLevel" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="ChangedBy" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="Justification" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Resource access template -->
                    <template tid="ResourceAccessTemplate">
                        <data name="AgentSid" inType="win:SID" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ResourceType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ResourcePath" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AccessType" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="OnBehalfOf" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>
                    <!-- Sandbox lifecycle template -->
                    <template tid="SandboxLifecycleTemplate">
                        <data name="SandboxName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SandboxDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SecurityProfile" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="Status" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="Endpoint" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="ModifiedBy" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="SourceIP" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>

                    <!-- Instruction GPO template -->
                    <template tid="InstructionGPOTemplate">
                        <data name="GPOName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="GPODN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="GPODisplayName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="InstructionPath" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="Priority" inType="win:UInt32" outType="xs:unsignedInt"/>
                        <data name="MergeStrategy" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentName" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="AgentDN" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="FailureReason" inType="win:UnicodeString" outType="xs:string"/>
                        <data name="CorrelationId" inType="win:GUID" outType="xs:GUID"/>
                    </template>
                </templates>

                <!-- Event Definitions -->
                <events>
                    <!-- Agent Lifecycle Events (1000-1099) -->
                    <event value="1000"
                           symbol="AGENT_CREATED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentLifecycle"
                           opcode="Start"
                           keywords="Agent Audit"
                           template="AgentLifecycleTemplate"
                           message="$(string.Event.AgentCreated)"/>

                    <event value="1001"
                           symbol="AGENT_MODIFIED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentLifecycle"
                           keywords="Agent Audit"
                           template="AgentLifecycleTemplate"
                           message="$(string.Event.AgentModified)"/>

                    <event value="1002"
                           symbol="AGENT_DELETED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentLifecycle"
                           opcode="Stop"
                           keywords="Agent Audit"
                           template="AgentLifecycleTemplate"
                           message="$(string.Event.AgentDeleted)"/>

                    <event value="1003"
                           symbol="AGENT_ENABLED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentLifecycle"
                           keywords="Agent Audit"
                           template="AgentLifecycleTemplate"
                           message="$(string.Event.AgentEnabled)"/>

                    <event value="1004"
                           symbol="AGENT_DISABLED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentLifecycle"
                           keywords="Agent Audit"
                           template="AgentLifecycleTemplate"
                           message="$(string.Event.AgentDisabled)"/>

                    <event value="1010"
                           symbol="AGENT_CREATION_FAILED"
                           version="1"
                           channel="Admin"
                           level="win:Warning"
                           task="AgentLifecycle"
                           keywords="Agent Audit"
                           template="AgentLifecycleTemplate"
                           message="$(string.Event.AgentCreationFailed)"/>

                    <event value="1011"
                           symbol="AGENT_CORRUPTED"
                           version="1"
                           channel="Admin"
                           level="win:Error"
                           task="AgentLifecycle"
                           keywords="Agent Security"
                           template="AgentBaseTemplate"
                           message="$(string.Event.AgentCorrupted)"/>

                    <!-- Authentication Events (2000-2099) -->
                    <event value="2000"
                           symbol="AGENT_LOGON_SUCCESS"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentAuthentication"
                           opcode="Start"
                           keywords="Agent Security Audit"
                           template="AuthenticationTemplate"
                           message="$(string.Event.AgentLogonSuccess)"/>

                    <event value="2001"
                           symbol="AGENT_LOGON_FAILURE"
                           version="1"
                           channel="Admin"
                           level="win:Warning"
                           task="AgentAuthentication"
                           keywords="Agent Security Audit"
                           template="AuthenticationTemplate"
                           message="$(string.Event.AgentLogonFailure)"/>

                    <event value="2002"
                           symbol="AGENT_LOGOFF"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="AgentAuthentication"
                           opcode="Stop"
                           keywords="Agent Audit"
                           template="AuthenticationTemplate"
                           message="$(string.Event.AgentLogoff)"/>

                    <event value="2020"
                           symbol="AGENT_CREDENTIAL_COMPROMISE"
                           version="1"
                           channel="Admin"
                           level="win:Critical"
                           task="AgentAuthentication"
                           keywords="Agent Security"
                           template="AuthenticationTemplate"
                           message="$(string.Event.AgentCredentialCompromise)"/>

                    <!-- Tool Access Events (3000-3099) -->
                    <event value="3000"
                           symbol="TOOL_ACCESS_GRANTED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="ToolAccess"
                           opcode="Grant"
                           keywords="Tool Audit"
                           template="ToolAccessTemplate"
                           message="$(string.Event.ToolAccessGranted)"/>

                    <event value="3001"
                           symbol="TOOL_ACCESS_DENIED"
                           version="1"
                           channel="Admin"
                           level="win:Warning"
                           task="ToolAccess"
                           opcode="Deny"
                           keywords="Tool Security Audit"
                           template="ToolAccessTemplate"
                           message="$(string.Event.ToolAccessDenied)"/>

                    <event value="3002"
                           symbol="TOOL_ACCESS_REVOKED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="ToolAccess"
                           opcode="Revoke"
                           keywords="Tool Audit"
                           template="ToolAccessTemplate"
                           message="$(string.Event.ToolAccessRevoked)"/>

                    <!-- Tool Execution Events (4000-4099) -->
                    <event value="4000"
                           symbol="TOOL_EXECUTION_STARTED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
