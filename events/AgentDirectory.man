                           message="$(string.Event.TrustLevelIncreased)"/>

                    <event value="7001"
                           symbol="TRUST_LEVEL_DECREASED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="TrustChange"
                           keywords="Agent Audit"
                           template="TrustChangeTemplate"
                           message="$(string.Event.TrustLevelDecreased)"/>

                    <!-- Resource Access Events (8000-8099) -->
                    <event value="8000"
                           symbol="FILE_ACCESS"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="ResourceAccess"
