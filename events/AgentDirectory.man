                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="ToolExecution"
                           opcode="Stop"
                           keywords="Tool Audit"
                           template="ToolExecutionTemplate"
                           message="$(string.Event.ToolExecutionCompleted)"/>

                    <event value="4002"
                           symbol="TOOL_EXECUTION_FAILED"
                           version="1"
                           channel="Admin"
                           level="win:Warning"
                           task="ToolExecution"
                           keywords="Tool Audit"
                           template="ToolExecutionTemplate"
                           message="$(string.Event.ToolExecutionFailed)"/>

                    <event value="4010"
                           symbol="TOOL_CONSTRAINT_VIOLATION"
                           version="1"
                           channel="Admin"
                           level="win:Warning"
                           task="ToolExecution"
                           keywords="Tool Security"
                           template="ToolExecutionTemplate"
                           message="$(string.Event.ToolConstraintViolation)"/>

                    <event value="4020"
                           symbol="TOOL_COMMAND_EXECUTED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="ToolExecution"
                           keywords="Tool Audit"
                           template="ToolExecutionTemplate"
                           message="$(string.Event.ToolCommandExecuted)"/>

                    <!-- Delegation Events (5000-5099) -->
                    <event value="5000"
                           symbol="DELEGATION_GRANTED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="Delegation"
                           opcode="Grant"
                           keywords="Delegation Audit"
                           template="DelegationTemplate"
                           message="$(string.Event.DelegationGranted)"/>

                    <event value="5001"
                           symbol="DELEGATION_REVOKED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="Delegation"
                           opcode="Revoke"
                           keywords="Delegation Audit"
                           template="DelegationTemplate"
                           message="$(string.Event.DelegationRevoked)"/>

                    <event value="5002"
                           symbol="DELEGATION_USED"
                           version="1"
                           channel="Operational"
                           level="win:Informational"
                           task="Delegation"
                           keywords="Delegation Audit"
